# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=langlisten
POSTGRES_PASSWORD=langlisten
POSTGRES_DB=langlisten
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local                  # local | minio
UPLOAD_DIR=uploads                     # local storage directory (relative to backend/)

# MinIO (only required when STORAGE_BACKEND=minio)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=langlisten
MINIO_SECURE=false

# ── Whisper ───────────────────────────────────────────────────────────────────
# Backend is auto-detected (no manual config needed):
#   Apple Silicon (arm64) → mlx-whisper (Metal GPU)
#   NVIDIA GPU            → faster-whisper (CUDA float16)
#   CPU fallback          → faster-whisper (CPU int8)
WHISPER_MODEL=medium                   # base | medium | large-v3
WHISPER_DEVICE=cpu                     # only used for CPU fallback
WHISPER_COMPUTE_TYPE=int8              # only used for CPU fallback

# ── LLM (AI explain feature) ──────────────────────────────────────────────────
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
